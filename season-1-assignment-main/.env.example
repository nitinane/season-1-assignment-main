# HireFlow AI - Environment Variables Template
# Copy this file to '.env' and populate with your credentials.

# Supabase Configurations
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Groq API Key for LLM Agents
VITE_GROQ_API_KEY=gsk_your_groq_api_key_here
VITE_GROQ_API_KEYS=key1,key2,key3,key4,key5
GROQ_API_KEYS=key1,key2,key3,key4,key5


# Telegram Notification Configurations (Agent 9)
VITE_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

